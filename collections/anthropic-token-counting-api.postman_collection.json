    "_postman_id": "fa804faa-3e6c-4881-9980-b7ab97a35347",
    "name": "Anthropic Token Counting API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Count the number of tokens in a Message, including tools, images, and documents, without creating it. The Token Count API accepts the same structured list of inputs for creating a message, including support for system prompts, tools, images, and PDFs. Token counting is free to use but subject to requests-per-minute rate limits.\n\n\nContact Support:\n Name: Anthropic Support",
      "type": "text/plain"
