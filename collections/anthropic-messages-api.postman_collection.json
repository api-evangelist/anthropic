                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"model\": \"claude-opus-4-6\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, Claude\"\n    }\n  ]\n}",
                  "options": {
